  m_Script: {fileID: 11500000, guid: 31e30ff387010004397177bce2d2d8e4, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Project.Quests.QuestGiverNpc
  npcId: pioneer_guide
  displayName: Pioneer Guide
  questOffers:
  - quest: {fileID: 11400000, guid: b4e2f8c91d3a4e5f9a0b1c2d3e4f5678, type: 2}
    prerequisiteQuestIds: []
    makeAvailableOnTalk: 1
    offerDialogue: Bring me 2 mushrooms. I will pay you in Pi and lend you a wood
      axe.
    progressDialogue: Still working on those mushrooms? Check the journal for progress.
    readyDialogue: You have what I need. Claim your reward.
    rewardDialogue: Well done, pioneer. Here is your payment and gear.
    doneDialogue: Thanks again. Stay safe out there.
  - quest: {fileID: 11400000, guid: a1b2c3d4e5f6789012345678abcdef12, type: 2}
    prerequisiteQuestIds: []
    makeAvailableOnTalk: 1
    offerDialogue: We need rocks for the camp foundation. Bring me 3 rocks.
    progressDialogue: Keep gathering rocks. Check the journal tracker for progress.
    readyDialogue: That is enough stone. Claim your reward.
    rewardDialogue: Good work. Here is your Pi.
    doneDialogue: The camp walls thank you.
  promptText: Press E to talk
  interactRange: 3.5
  questBoardIntro: Pick a quest below to accept, track progress, or claim rewards.
  idleAnimatorController: {fileID: 9100000, guid: f1c8e4a27b3d94f5a8c2e1d0b9f8a7c6, type: 2}
  idleStateName: Idle
